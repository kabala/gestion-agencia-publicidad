<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Agencia Creativa</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<header>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
<div class="container">
<a class="navbar-brand fw-semibold" asp-controller="Home" asp-action="Index">Agencia Creativa</a>
<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu"><span class="navbar-toggler-icon"></span></button>
<div class="collapse navbar-collapse" id="menu">
<ul class="navbar-nav ms-auto">
<li class="nav-item"><a class="nav-link" asp-controller="Clientes" asp-action="Index">Clientes</a></li>
<li class="nav-item"><a class="nav-link" asp-controller="Campanas" asp-action="Index">CampaŮas</a></li>
<li class="nav-item"><a class="nav-link" asp-controller="Disenadores" asp-action="Index">DiseŮadores</a></li>
<li class="nav-item"><a class="nav-link" asp-controller="Entregables" asp-action="Index">Entregables</a></li>
</ul>
</div>
</div>
</nav>
</header>
<main class="container py-4">@RenderBody()</main>
<footer class="border-top py-3 mt-4 text-muted"><div class="container">Sistema de Gestiůn de Agencia de Publicidad - 2026</div></footer>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>


