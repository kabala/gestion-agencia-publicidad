@using AngularApp3.Server.Models
@{ ViewData["Title"] = "Inicio"; var proximos = ViewBag.Proximos as List<Entregable>; }
<div class="mb-4">
<h1 class="h2">Panel de la agencia</h1>
<p class="text-muted">Resumen general de clientes, campaŮas y trabajo creativo.</p>
</div>
<div class="row g-3 mb-5">
<div class="col-md-3"><div class="card summary-card border-primary"><div class="card-body"><div class="text-muted">Clientes</div><div class="display-6">@ViewBag.Clientes</div><a asp-controller="Clientes" asp-action="Index">Ver clientes</a></div></div></div>
<div class="col-md-3"><div class="card summary-card border-success"><div class="card-body"><div class="text-muted">CampaŮas</div><div class="display-6">@ViewBag.Campanas</div><a asp-controller="Campanas" asp-action="Index">Ver campaŮas</a></div></div></div>
<div class="col-md-3"><div class="card summary-card border-warning"><div class="card-body"><div class="text-muted">DiseŮadores</div><div class="display-6">@ViewBag.Disenadores</div><a asp-controller="Disenadores" asp-action="Index">Ver diseŮadores</a></div></div></div>
<div class="col-md-3"><div class="card summary-card border-danger"><div class="card-body"><div class="text-muted">Entregables</div><div class="display-6">@ViewBag.Entregables</div><a asp-controller="Entregables" asp-action="Index">Ver entregables</a></div></div></div>
</div>
<div class="d-flex justify-content-between align-items-center mb-3"><h2 class="h4 mb-0">Průximos entregables</h2><a class="btn btn-primary" asp-controller="Entregables" asp-action="Create">Nuevo entregable</a></div>
<div class="table-responsive"><table class="table table-hover align-middle"><thead class="table-light"><tr><th>Tipo</th><th>CampaŮa</th><th>DiseŮador</th><th>Fecha</th></tr></thead><tbody>
@foreach (var item in proximos ?? []) { <tr><td>@item.Tipo</td><td>@item.Campana?.Nombre</td><td>@item.Disenador?.Nombre</td><td>@item.FechaEntrega.ToString("dd/MM/yyyy")</td></tr> }
</tbody></table></div>


